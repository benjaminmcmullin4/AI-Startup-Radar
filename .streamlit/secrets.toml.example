# Streamlit Cloud Secrets Configuration
# In Streamlit Cloud: Settings > Secrets > paste these with real values

# AI API Keys (at least one enables AI-powered features)
OPENAI_API_KEY = ""
ANTHROPIC_API_KEY = ""

# Email OTP Authentication (optional — without SMTP, codes show on screen)
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = ""
SMTP_PASSWORD = ""
FROM_EMAIL = ""

# Restrict access to specific email domains (comma-separated, empty = allow all)
# Example: "mercatopartners.com,gmail.com"
ALLOWED_EMAIL_DOMAINS = ""
