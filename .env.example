# AI Startup Radar — Environment Variables
# Copy to .env and fill in your API keys

# OpenAI API key (optional — enables AI-powered memos and enrichment)
OPENAI_API_KEY=

# Anthropic API key (optional — enables AI-powered memos and enrichment)
ANTHROPIC_API_KEY=

# Resend API key (optional — enables email OTP delivery)
RESEND_API_KEY=

# Crunchbase API key (optional — enables real startup data search and import)
CRUNCHBASE_API_KEY=

# If no API keys are set, the app runs in demo mode with rule-based scoring
# and template-based memos (fully functional, no AI features)
